SOURCE_ROOT = REPO_ROOT / "{{ provider_path.rstrip('/') }}"


def find_violations() -> dict[str, list[str]]:
    """Return ``{repo-relative path: [messages]}`` for misplaced methods."""
    violations: dict[str, list[str]] = {}
