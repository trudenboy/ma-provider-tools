# Auto-generated by ma-provider-tools — do not edit manually.
repos:
  - repo: local
    hooks:
      - id: ruff-check
        name: 🐶 Ruff Linter
        language: system
        types: [python]
        files: ^({{ provider_path }}.*\.py|tests/.*\.py)$
        entry: uv run --active --no-project --with 'ruff<0.15' ruff check --fix
        require_serial: true
        stages: [pre-commit, pre-push, manual]

      - id: ruff-format
        name: 🐶 Ruff Formatter
        language: system
        types: [python]
        files: ^({{ provider_path }}.*\.py|tests/.*\.py)$
        entry: uv run --active --no-project --with 'ruff<0.15' ruff format
        require_serial: true
        stages: [pre-commit, pre-push, manual]

      - id: check-ast
        name: 🐍 Check Python AST
        language: system
        types: [python]
        entry: uv run --active --no-project check-ast

      - id: check-json
        name: ｛ Check JSON files
        language: system
        types: [json]
        entry: uv run --active --no-project check-json
        files: ^({{ manifest_path | replace('/', '\\/') }})|(tests/fixtures/.+\.json)$

      - id: check-toml
        name: ✅ Check TOML files
        language: system
        types: [toml]
        entry: uv run --active --no-project check-toml

      - id: check-merge-conflict
        name: 💥 Check for merge conflicts
        language: system
        types: [text]
        entry: uv run --active --no-project check-merge-conflict

      - id: codespell
        name: ✅ Check code for common misspellings
        language: system
        types: [text]
        entry: uv run --active --no-project codespell

      - id: detect-private-key
        name: 🕵️ Detect Private Keys
        language: system
        types: [text]
        entry: uv run --active --no-project detect-private-key

      - id: end-of-file-fixer
        name: ⮐ Fix End of Files
        language: system
        types: [text]
        entry: uv run --active --no-project end-of-file-fixer
        stages: [pre-commit, pre-push, manual]

      - id: no-commit-to-branch
        name: 🛑 Don't commit to main branch
        language: system
        entry: uv run --active --no-project no-commit-to-branch
        pass_filenames: false
        always_run: true
        args:
          - --branch=main

      - id: trailing-whitespace
        name: ✄ Trim Trailing Whitespace
        language: system
        types: [text]
        entry: uv run --active --no-project trailing-whitespace-fixer
        stages: [pre-commit, pre-push, manual]

      # Mirrors upstream music-assistant/server check_method_order (AGENTS.md:
      # private methods live at the bottom of each class) so the rule fails
      # here instead of at the first upstream PR (ma-provider-tools#115).
      - id: check-method-order
        name: 🔤 Check method order (private methods last)
        language: system
        entry: uv run --active --no-project python scripts/check_method_order.py
        pass_filenames: false
        files: ^({{ provider_path }}.*\.py|scripts/check_method_order\.py)$

      - id: mypy
        name: 🔍 Mypy Type Checker
        entry: uv run --active --no-project mypy
        language: system
        types: [python]
        require_serial: true
        pass_filenames: false
