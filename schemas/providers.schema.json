{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/trudenboy/ma-provider-tools/schemas/providers.schema.json",
  "title": "ma-provider-tools providers registry",
  "description": "Schema for providers.yml — the single source of truth driving distribute.py.",
  "type": "object",
  "required": ["providers"],
  "additionalProperties": false,
  "properties": {
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/provider" }
    }
  },
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "display_name",
        "repo",
        "default_branch",
        "provider_type"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Snake-case provider identifier; matches manifest.json:domain."
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*/[A-Za-z0-9][A-Za-z0-9._-]*$",
          "description": "GitHub <owner>/<name> slug."
        },
        "default_branch": {
          "type": "string",
          "minLength": 1
        },
        "provider_type": {
          "type": "string",
          "enum": [
            "music_provider",
            "player_provider",
            "plugin_provider",
            "server_fork"
          ]
        },
        "manifest_path": {
          "type": "string",
          "pattern": "^[^/].*manifest\\.json$"
        },
        "provider_path": {
          "type": "string",
          "pattern": "^[^/].*/$"
        },
        "locale": {
          "type": "string",
          "pattern": "^[a-z]{2}$"
        },
        "service_url": {
          "type": "string",
          "format": "uri"
        },
        "auth_method": {
          "type": "string",
          "minLength": 1
        },
        "max_quality": {
          "type": "string",
          "minLength": 1
        },
        "features": {
          "type": "array",
          "items": { "$ref": "#/$defs/feature" }
        },
        "runtime_dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "extra_test_dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "codespell_ignore_words": {
          "type": "string"
        },
        "python_version": {
          "type": "string",
          "pattern": "^3\\.\\d{1,2}$"
        },
        "legacy_files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "skip_wrappers": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._/-]+\\.(j2|md|yml|yaml)$"
          }
        },
        "github_description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 120,
          "pattern": "^[^\\n]+$",
          "description": "Single-line repo About text rendered on the GitHub page and consumed by sync_repo_settings.py."
        },
        "github_topics": {
          "type": "array",
          "minItems": 3,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,49}$"
          },
          "description": "GitHub topic list (lowercase, hyphens, English-only). RU-first repos add transliterated brand keywords + 'russia' / 'russian-music'."
        },
        "github_homepage": {
          "type": "string",
          "format": "uri",
          "description": "Optional override for the repo Homepage URL. Defaults to https://trudenboy.github.io/<basename(repo)>/ when absent."
        },
        "related_providers": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "description": "Cross-link map: each entry MUST be another provider's domain. Rendered as the 'Related providers' line in README header and docs-site homepage."
        }
      },
      "allOf": [
        {
          "description": "Non-fork providers must declare the full provider surface.",
          "if": {
            "properties": { "provider_type": { "const": "server_fork" } },
            "required": ["provider_type"]
          },
          "then": {},
          "else": {
            "required": [
              "manifest_path",
              "provider_path",
              "locale",
              "service_url",
              "auth_method",
              "max_quality",
              "features"
            ]
          }
        }
      ]
    },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^features/[a-z][a-z0-9-]*$",
          "description": "Stable slug for docs/ deep-link. May map to a ProviderFeature enum via feature_id."
        },
        "feature_id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "description": "ProviderFeature enum member; cross-validated against provider/__init__.py SUPPORTED_FEATURES by check_feature_consistency.py."
        }
      }
    }
  }
}
